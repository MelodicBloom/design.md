{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "enabled": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["lint", "build"],
      "cache": true,
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
